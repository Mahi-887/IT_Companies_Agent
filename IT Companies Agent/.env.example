# ============================================================
# DevPulse AI — Environment Variables TEMPLATE
# ============================================================
# Yeh file GitHub pe push karo (safe hai — koi real key nahi).
# Apni machine pe isko copy karke .env naam do aur values bharo.
# ============================================================

# Google Gemini API Key (https://aistudio.google.com/app/apikey)
AG_API_KEY=your_google_gemini_api_key_here

# Project Settings
DEVPULE_PROJECT_NAME=DevPulse AI
DEVPULE_PROJECT_VERSION=0.1.0
DEVPULE_API_PREFIX=/api/v1

# Database URL
DATABASE_URL=sqlite+aiosqlite:///./devpulse.db

# JWT Secret Key
DEVPULE_JWT_SECRET=change_this_to_a_strong_random_secret_key

# Google AI Model
DEVPULE_GOOGLE_MODEL=gemini-1.5-flash
